# Ollama (local LLM — everything runs on your machine)
# Start with: ollama serve
# No API keys needed. No data leaves your laptop.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_CHAT_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=1200

# File limits
MAX_RESUMES=50
MAX_FILE_SIZE_MB=10
MAX_JD_CHARS=50000

# Feature flags (set to false to disable)
FEATURE_JD_FILE_UPLOAD=true
FEATURE_OPTIONAL_ROLE=true
FEATURE_IMPROVEMENT_SUGGESTIONS=true
FEATURE_SCORE_NORMALIZATION=true

# AI analysis feature flags
ENABLE_SEMANTIC_SKILLS=true
ENABLE_LLM_EXPERIENCE=true
ENABLE_ACHIEVEMENT_ANALYSIS=true
ENABLE_CAREER_TRAJECTORY=true
ENABLE_MULTI_DIM_FIT=true
ENABLE_RED_FLAG_DETECTION=true
ENABLE_COMPARATIVE_RANKING=true
SEMANTIC_SKILL_THRESHOLD=0.75
